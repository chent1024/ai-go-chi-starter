# 本地开发环境
# APP_ENV 可选值：development、staging、production
APP_ENV=development

# PostgreSQL DSN 示例：
# postgres://<user>:<password>@<host>:<port>/<db>?sslmode=disable
APP_DATABASE_URL=postgres://app:app@127.0.0.1:5432/app?sslmode=disable
APP_DATABASE_MAX_OPEN_CONNS=25
APP_DATABASE_MAX_IDLE_CONNS=25
APP_DATABASE_CONN_MAX_LIFETIME=30m
APP_DATABASE_CONN_MAX_IDLE_TIME=15m

# HTTP 服务
APP_API_LISTEN_ADDR=:8080
APP_API_SHUTDOWN_TIMEOUT=10s
APP_API_READ_TIMEOUT=15s
APP_API_WRITE_TIMEOUT=30s
APP_API_IDLE_TIMEOUT=60s
APP_API_REQUEST_TIMEOUT=30s
APP_API_MAX_HEADER_BYTES=1048576
APP_API_MAX_BODY_BYTES=1048576

# Worker
# APP_WORKER_ENABLED 可选值：true、false
APP_WORKER_ENABLED=true
APP_WORKER_POLL_INTERVAL=5s
APP_WORKER_SHUTDOWN_TIMEOUT=10s

# 日志
# APP_LOG_LEVEL 可选值：debug、info、warn、error
# APP_LOG_FORMAT 可选值：text、json
# APP_LOG_OUTPUT 可选值：stdout、file、both
APP_LOG_LEVEL=debug
APP_LOG_FORMAT=text
APP_LOG_OUTPUT=stdout
APP_LOG_DIR=./.runtime/logs
APP_LOG_RETENTION_DAYS=7
APP_LOG_CLEANUP_INTERVAL=1h
APP_LOG_ACCESS_ENABLED=true
APP_LOG_SOURCE_ENABLED=false
APP_LOG_OUTBOUND_ENABLED=true
APP_LOG_OUTBOUND_LEVEL=debug

# 出站 HTTP 客户端
APP_OUTBOUND_TIMEOUT=30s
APP_OUTBOUND_MAX_IDLE_CONNS=100
APP_OUTBOUND_MAX_IDLE_CONNS_PER_HOST=10
APP_OUTBOUND_IDLE_CONN_TIMEOUT=90s
APP_OUTBOUND_TLS_HANDSHAKE_TIMEOUT=10s
APP_OUTBOUND_RESPONSE_HEADER_TIMEOUT=15s
APP_OUTBOUND_EXPECT_CONTINUE_TIMEOUT=1s

# 时区示例：UTC、Asia/Shanghai、America/Los_Angeles
APP_TIMEZONE=UTC

# 本地 Docker PostgreSQL
# 这些 key 只用于本地开发时的 docker compose。
DOCKER_POSTGRES_HOST_PORT=5432
DOCKER_POSTGRES_DB=app
DOCKER_POSTGRES_USER=app
DOCKER_POSTGRES_PASSWORD=app
