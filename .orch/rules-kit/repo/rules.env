# Copy this file into the target repo and adjust every path and command.

REPO_ROOT="."

VERIFY_CMD="make verify"
STRICT_VERIFY_CMD="make verify-strict"

# Space-separated config source files inspected for env var reads.
CONFIG_SOURCES="app/internal/config/config.go"
ENV_EXAMPLE_FILE="deploy/.env.dev.example"
ALLOW_STALE_ENV_EXAMPLE_KEYS="false"

# Space-separated API surface and contract paths.
API_SURFACE_PATHS="app/internal/httpapi app/internal/transport/httpapi/router.go app/internal/transport/httpapi/public app/internal/transport/httpapi/internal app/internal/transport/httpapi/httpx app/internal/transport/httpapi/security app/internal/api"
CONTRACT_PATHS="app/openapi app/api"
CONTRACT_SYNC_BASE_REF="HEAD~1"

# Optional route/contract parity check. Current generic backend compares
# normalized route manifests exported by the repo itself.
CONTRACT_PARITY_BACKEND=""
CONTRACT_PARITY_ROUTE_MANIFEST_FILE=""
CONTRACT_PARITY_CONTRACT_MANIFEST_FILE=""

# Optional change scope gating. Current openspec backend reads the selected
# change's .openspec.yaml and checks that changed files stay within scope_paths.
CHANGE_SCOPE_BACKEND=""
CHANGE_SCOPE_MODE="strict"
CHANGE_SCOPE_BASE_REF="HEAD~1"
CHANGE_SCOPE_ROOT="openspec/changes"
CHANGE_SCOPE_ACTIVE_CHANGE=""
CHANGE_SCOPE_METADATA_FILE=".openspec.yaml"
CHANGE_SCOPE_CODE_PATHS=""
CHANGE_SCOPE_ALLOW_PATHS=""
OPENSPEC_REQUIRED_MODE="smart"
OPENSPEC_REQUIRED_PATHS=""

# Optional code-to-doc sync rules. Each line is:
# <code path>[,<code path>...]|<doc path>[,<doc path>...]|<failure message>
DOC_SYNC_RULES_FILE=""
DOC_SYNC_BASE_REF="HEAD~1"
# Optional local override file loaded automatically by verify scripts:
# .orch/rules/<target>/local.env

# Patterns used to identify generated files.
GENERATED_MARKERS="Code generated|DO NOT EDIT|AUTO-GENERATED FILE"

# Space-separated scan roots and optional exclude globs.
SECRET_SCAN_PATHS="."
SECRET_SCAN_EXCLUDE_GLOBS=".git/** vendor/** node_modules/** .orch/runtime/**"

# Forward-only migration defaults.
MIGRATIONS_DIR="app/db/migrations"
MIGRATION_BASE_REF="HEAD~1"
MIGRATION_FILE_REGEX='^[^[:space:]]+/[0-9]{3,}.*\.(sql|up\.sql|down\.sql)$'
ALLOW_EDIT_EXISTING_MIGRATIONS="false"

# Architecture checks are repo-specific. Point this to a file where each line is:
# <scope>|<regex>|<human readable failure message>
ARCH_IMPORT_RULES_FILE=""
ARCH_BACKEND="text"
GO_LAYOUT_PROFILE=""

# Optional layout checks. Space-separated paths relative to REPO_ROOT.
LAYOUT_REQUIRED_DIRS=""
LAYOUT_FORBIDDEN_DIRS=""
