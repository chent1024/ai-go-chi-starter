REPO_ROOT="."

VERIFY_CMD="make verify"
STRICT_VERIFY_CMD="make verify-strict"

CONFIG_SOURCES="internal/config/config.go"
ENV_EXAMPLE_FILE=".env.example"
ALLOW_STALE_ENV_EXAMPLE_KEYS="false"

API_SURFACE_PATHS="internal/httpapi internal/transport/httpapi/router.go internal/transport/httpapi/public internal/transport/httpapi/internal internal/transport/httpapi/httpx internal/transport/httpapi/security internal/api"
CONTRACT_PATHS="openapi api openapi.yaml"
CONTRACT_SYNC_BASE_REF="HEAD~1"
CONTRACT_PARITY_BACKEND=""
CONTRACT_PARITY_ROUTE_MANIFEST_FILE=""
CONTRACT_PARITY_CONTRACT_MANIFEST_FILE=""
CHANGE_SCOPE_BACKEND=""
CHANGE_SCOPE_BASE_REF="HEAD~1"
CHANGE_SCOPE_ROOT="openspec/changes"
CHANGE_SCOPE_ACTIVE_CHANGE=""
CHANGE_SCOPE_METADATA_FILE=".openspec.yaml"
DOC_SYNC_RULES_FILE=""
DOC_SYNC_BASE_REF="HEAD~1"

GENERATED_MARKERS="Code generated|DO NOT EDIT|AUTO-GENERATED FILE"

SECRET_SCAN_PATHS="."
SECRET_SCAN_EXCLUDE_GLOBS=".git/** vendor/** node_modules/** .orch/runtime/** dist/** build/**"

MIGRATIONS_DIR="db/migrations"
MIGRATION_BASE_REF="HEAD~1"
MIGRATION_FILE_REGEX='^[^[:space:]]+/[0-9]{3,}.*\.(sql|up\.sql|down\.sql)$'
ALLOW_EDIT_EXISTING_MIGRATIONS="false"

ARCH_IMPORT_RULES_FILE=""
ARCH_BACKEND="go_imports"
GO_LAYOUT_PROFILE="service_layered"
LAYOUT_REQUIRED_DIRS="cmd internal/config internal/runtime internal/transport/httpapi internal/service internal/infra openapi db/migrations"
LAYOUT_FORBIDDEN_DIRS="internal/handlers internal/repository internal/storage internal/upload internal/misc internal/tmp"
