# Generated by rules-kit/install.sh. Prefer editing .orch/rules/manifest.json and re-running install.
TOOLS_BIN ?= $(CURDIR)/.tools/bin
GOLANGCI_LINT ?= $(TOOLS_BIN)/golangci-lint
GOLANGCI_LINT_VERSION ?= v1.64.8
GOLANGCI_LINT_ARGS ?= --tests=false

$(GOLANGCI_LINT):
	mkdir -p $(TOOLS_BIN)
	GOBIN=$(TOOLS_BIN) go install github.com/golangci/golangci-lint/cmd/golangci-lint@$(GOLANGCI_LINT_VERSION)

.PHONY: verify verify-strict verify-common
.PHONY: verify-app verify-strict-app

verify: verify-common verify-app
verify-strict: verify verify-strict-app

verify-common:
	bash .orch/rules/scripts/verify-generated.sh .orch/rules/global.env
	bash .orch/rules/scripts/verify-secrets.sh .orch/rules/global.env

verify-app: $(GOLANGCI_LINT)
	@out=$$(cd app && gofmt -l $$(find . -type f -name '*.go' -not -path './.tools/*')); \
	if [ -n "$$out" ]; then \
		echo "gofmt required for:"; \
		echo "$$out"; \
		exit 1; \
	fi
	cd app && $(GOLANGCI_LINT) run $(GOLANGCI_LINT_ARGS) --config $(CURDIR)/.orch/rules/lint/.golangci.base.yml ./...
	cd app && go test ./...
	bash .orch/rules/scripts/verify-config-docs.sh .orch/rules/app/rules.env

verify-strict-app: verify-app
	cd app && go test -race ./...
	cd app && go test -run '^$$' -bench . -benchmem ./...
	bash .orch/rules/scripts/verify-doc-sync.sh .orch/rules/app/rules.env
	bash .orch/rules/scripts/verify-layout.sh .orch/rules/app/rules.env
	bash .orch/rules/scripts/verify-contract-parity.sh .orch/rules/app/rules.env
	bash .orch/rules/scripts/verify-openspec-required.sh .orch/rules/app/rules.env
	bash .orch/rules/scripts/verify-change-scope.sh .orch/rules/app/rules.env
	bash .orch/rules/scripts/verify-migrations.sh .orch/rules/app/rules.env
	bash .orch/rules/scripts/verify-arch.sh .orch/rules/app/rules.env
